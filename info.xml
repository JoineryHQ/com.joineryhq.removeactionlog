<?xml version="1.0"?>
<extension key="au.com.agileware.removeactionlog" type="module">
  <file>removeactionlog</file>
  <name>Action Log Cleaner</name>
  <description>Clears Membership Renewal Reminders from the action log when they're no longer required</description>
  <license>GPL-3.0</license>
  <maintainer>
    <author>Allen Shaw, based on work by Agileware</author>
    <email>allen@joineryhq.com</email>
  </maintainer>
  <urls>
    <url desc="Original Agileware Extension Page">https://bitbucket.org/agileware/au.com.agileware.removeactionlog</url>
    <url desc="Forked Joinery Extension Page">https://github.comJoineryHQ/com.joineryhq.removeactionlog</url>
    <url desc="Documentation">https://github.comJoineryHQ/com.joineryhq.removeactionlog</url>
    <url desc="Support">https://github.comJoineryHQ/com.joineryhq.removeactionlog/issues</url>
    <url desc="Licensing">http://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <releaseDate>2017-01-14</releaseDate>
  <version>1.0</version>
  <develStage>alpha</develStage>
  <compatibility>
    <ver>5.51</ver>
  </compatibility>
  <comments>This is a new, undeveloped module</comments>
  <civix>
    <namespace>CRM/Removeactionlog</namespace>
    <format>25.10.2</format>
  </civix>
  <mixins>
    <mixin>mgd-php@2.0.0</mixin>
    <mixin>scan-classes@1.0.0</mixin>
  </mixins>
  <classloader>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
</extension>
